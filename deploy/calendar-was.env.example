# was-01/app.env 예시. 이 파일을 서버의 was-01/app.env 로 복사한 뒤 값을 채운다.
# !! app.env(실값)는 커밋하지 않는다. systemd EnvironmentFile로 주입됨.
#
# MySQL은 Docker 컨테이너로 구동 중 → host에 published된 포트로 접속.
#   포트 확인: docker ps  (보통 3306:3306 이면 아래 그대로)
DB_URL=jdbc:mysql://127.0.0.1:3306/photocalendar?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false
DB_USER=photocalendar
DB_PASSWORD=__여기에_DB_비밀번호__

# JWT 서명 키 — 최소 32바이트 랜덤. 예: openssl rand -base64 48
JWT_SECRET=__여기에_랜덤_시크릿__
JWT_EXPIRATION_DAYS=7

# same-origin이라 실제로는 불필요하지만 명시(도메인)
CORS_ALLOWED_ORIGINS=https://calendar.kebab-lee.com

# 업로드 사진 저장 위치 (배포 산출물과 분리, 영속)
UPLOAD_DIR=/home/kebab/projects/kebab-calendar/uploads
