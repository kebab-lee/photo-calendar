<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.photocalendar.calendar.mapper.UserMapper">

    <!-- created_at은 DB DEFAULT(CURRENT_TIMESTAMP)에 위임 -->
    <insert id="insert" parameterType="com.photocalendar.calendar.domain.User"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (email, password_hash)
        VALUES (#{email}, #{passwordHash})
    </insert>

    <select id="findByEmail" resultType="com.photocalendar.calendar.domain.User">
        SELECT id, email, password_hash, created_at
        FROM `user`
        WHERE email = #{email}
    </select>

    <select id="findById" resultType="com.photocalendar.calendar.domain.User">
        SELECT id, email, password_hash, created_at
        FROM `user`
        WHERE id = #{id}
    </select>
</mapper>
